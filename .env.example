# Configuración de Variables de Entorno
# Copia este archivo a .env y completa con tus valores

# API Configuration
API_BASE_URL=http://localhost:8000
API_KEY=your_api_key_here
API_TIMEOUT=30

# Application Configuration
APP_BASE_URL=http://localhost:3000
APP_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/test_db

# Browser Configuration
BROWSER_TYPE=chrome
HEADLESS=False
BROWSER_TIMEOUT=30

# Performance Testing
PERFORMANCE_THREADS=10
PERFORMANCE_RAMP_TIME=60
PERFORMANCE_LOOP_COUNT=10

# Reporting
REPORT_PATH=./reports
SCREENSHOTS_PATH=./evidences/screenshots
LOGS_PATH=./evidences/logs

# Logging
LOG_LEVEL=INFO
LOG_FILE=./evidences/logs/test.log

# CI/CD
CI_ENVIRONMENT=false
PARALLEL_EXECUTION=false
MAX_RETRIES=3
